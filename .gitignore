# ============================================================
# Laravel — Comprehensive .gitignore
# ============================================================

# ----- Environment & Secrets --------------------------------
.env
.env.*
!.env.example
.env.backup
.env.production
.env.*.local
/auth.json
/storage/*.key

# ----- Dependencies (reinstalled via composer/npm) ----------
/vendor
/node_modules

# ----- Laravel Generated / Cached ---------------------------
/bootstrap/cache/*
!/bootstrap/cache/.gitignore
/bootstrap/cache/*.php
/bootstrap/cache/*.tmp
/storage/app/public/*
!/storage/app/public/.gitignore
!/storage/app/public/.gitkeep
/storage/app/reports/
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/testing/*
/storage/pail
/storage/logs/*.log
/storage/logs/*.txt

# ----- Build Artifacts --------------------------------------
/public/build
/public/hot
/public/storage
/public/uploads/
/public/media/
/public/news/
/public/temp/
/public/mix-manifest.json
/public/css/*.map
/public/js/*.map

# ----- IDE & OS Files ----------------------------------------
.DS_Store
._*
Thumbs.db
desktop.ini
/.idea
/.vscode
/.nova
/.zed
/.cursor/
/.codex
/.laragon/

# ----- PHP Tools & Misc -------------------------------------
*.log
.phpactor.json
.phpunit.result.cache
/.phpunit.cache
/coverage
_ide_helper.php
Homestead.json
Homestead.yaml

# ----- SQLite Databases (local dev only) --------------------
/database/*.sqlite
/database/*.sqlite-journal
/database/*.sqlite-shm
/database/*.sqlite-wal

# ----- Node / Package Manager Logs & Cache -------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/.npm
/.yarn
/.pnpm-store
/.vite

# ----- Temp & Archive Files ---------------------------------
resources.zip
/frontend-demo/dist/
/dist/
/build/
/tmp/
/temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*.orig
*.rej
*.zip
*.tar
*.tar.gz

# Keep placeholder .gitignore files inside storage directories
!storage/app/.gitignore
!storage/app/private/.gitignore
!storage/app/public/.gitignore
!storage/framework/.gitignore
!storage/framework/cache/.gitignore
!storage/framework/cache/data/.gitignore
!storage/framework/sessions/.gitignore
!storage/framework/testing/.gitignore
!storage/framework/views/.gitignore
!storage/logs/.gitignore
